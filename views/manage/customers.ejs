<%- include('../partials/header', { title: 'Manage Customers', message }) %>
<% const canDeleteCustomers = ['employee', 'manager', 'admin'].includes(auth.role); %>
<% const showAdminAccountDetails = auth.role === 'admin'; %>
<% const customerColumnCount = showAdminAccountDetails ? (canDeleteCustomers ? 11 : 10) : (canDeleteCustomers ? 10 : 9); %>

<section class="page-intro">
  <h2>Customer Records</h2>
  <p>Register customers at the front desk using SIN and contact information.</p>
</section>

<section class="card">
  <h2>Create Customer</h2>
  <form method="POST" action="/manage/customers" class="grid form-grid">
    <label>SIN
      <input
        name="legal_id"
        type="tel"
        inputmode="numeric"
        pattern="\d{9}"
        minlength="9"
        maxlength="9"
        placeholder="111111111"
        title="SIN must contain exactly 9 digits."
        required
      />
    </label>
    <label>ID Type
      <input value="SIN" readonly />
      <input type="hidden" name="id_type" value="SIN" />
    </label>
    <label>First Name <input name="first_name" maxlength="80" required /></label>
    <label>Last Name <input name="last_name" maxlength="80" required /></label>
    <label>Email <input type="email" name="email" maxlength="120" required /></label>
    <label>Phone
      <input
        name="phone"
        type="tel"
        inputmode="numeric"
        pattern="\d{10}"
        minlength="10"
        maxlength="10"
        title="Phone must contain exactly 10 digits."
        required
      />
    </label>
    <label>Address <input name="address_line" maxlength="255" required /></label>
    <label>Registration Date <input type="date" name="registration_date" required /></label>
    <div class="actions"><button type="submit">Create</button></div>
  </form>
</section>

<section class="card">
  <h2>Customers</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>SIN (Primary ID)</th>
          <th>Name</th>
          <th>Hotel</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Registration</th>
          <% if (showAdminAccountDetails) { %>
            <th>Username</th>
          <% } %>
          <th>Account Status</th>
          <th>Update</th>
          <th>Enable/Disable</th>
          <% if (canDeleteCustomers) { %><th>Delete</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% if (customers.length === 0) { %>
          <tr><td colspan="<%= customerColumnCount %>" class="data-empty">No customer records found.</td></tr>
        <% } %>
        <% customers.forEach(c => { %>
          <tr>
            <td><%= c.legal_id %></td>
            <td><%= c.first_name %> <%= c.last_name %></td>
            <td><%= c.hotel_name || 'Unassigned' %></td>
            <td><%= c.email %></td>
            <td><%= c.phone %></td>
            <td><%= c.registration_date.toISOString().slice(0,10) %></td>
            <% if (showAdminAccountDetails) { %>
              <td><%= c.username || `customer${c.customer_id}` %></td>
            <% } %>
            <td>
              <% if (!c.account_id) { %>
                <span class="status-badge">missing</span>
              <% } else { %>
                <span class="status-badge <%= c.is_active ? 'status-active' : 'status-cancelled' %>">
                  <%= c.is_active ? 'active' : 'inactive' %>
                </span>
              <% } %>
            </td>
            <td>
              <form method="POST" action="/manage/customers/<%= c.customer_id %>?_method=PATCH" class="inline-form stack-small">
                <input name="first_name" value="<%= c.first_name %>" maxlength="80" required />
                <input name="last_name" value="<%= c.last_name %>" maxlength="80" required />
                <input type="email" name="email" value="<%= c.email %>" maxlength="120" required />
                <input
                  name="phone"
                  value="<%= String(c.phone || '').replace(/\\D/g, '').slice(0, 10) %>"
                  type="tel"
                  inputmode="numeric"
                  pattern="\d{10}"
                  minlength="10"
                  maxlength="10"
                  title="Phone must contain exactly 10 digits."
                  required
                />
                <input name="address_line" value="<%= c.address_line %>" maxlength="255" required />
                <input type="date" name="registration_date" value="<%= c.registration_date.toISOString().slice(0,10) %>" required />
                <button type="submit">Save</button>
              </form>
            </td>
            <td>
              <form method="POST" action="/manage/customers/<%= c.customer_id %>/account-status?_method=PATCH">
                <input type="hidden" name="is_active" value="<%= c.is_active ? 'false' : 'true' %>" />
                <button type="submit" class="<%= c.is_active ? 'danger' : '' %>">
                  <%= c.is_active ? 'Disable' : 'Enable' %>
                </button>
              </form>
            </td>
            <% if (canDeleteCustomers) { %>
              <td>
                <form method="POST" action="/manage/customers/<%= c.customer_id %>?_method=DELETE">
                  <button type="submit" class="danger">Delete</button>
                </form>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/footer') %>
