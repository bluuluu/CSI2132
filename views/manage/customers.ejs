<%- include('../partials/header', { title: 'Manage Customers', message }) %>

<section class="card">
  <h2>Create Customer</h2>
  <form method="POST" action="/manage/customers" class="grid form-grid">
    <label>Legal ID <input name="legal_id" required /></label>
    <label>ID Type
      <select name="id_type" required>
        <% ['SIN','SSN','DL','PASSPORT'].forEach(t => { %><option value="<%= t %>"><%= t %></option><% }) %>
      </select>
    </label>
    <label>First Name <input name="first_name" required /></label>
    <label>Last Name <input name="last_name" required /></label>
    <label>Email <input type="email" name="email" required /></label>
    <label>Phone <input name="phone" required /></label>
    <label>Address <input name="address_line" required /></label>
    <label>Registration Date <input type="date" name="registration_date" required /></label>
    <div class="actions"><button type="submit">Create</button></div>
  </form>
</section>

<section class="card">
  <h2>Customers</h2>
  <div class="table-wrap">
    <table>
      <thead><tr><th>ID</th><th>Legal ID</th><th>Name</th><th>Email</th><th>Phone</th><th>Registration</th><th>Update</th><th>Delete</th></tr></thead>
      <tbody>
        <% customers.forEach(c => { %>
          <tr>
            <td><%= c.customer_id %></td>
            <td><%= c.legal_id %></td>
            <td><%= c.first_name %> <%= c.last_name %></td>
            <td><%= c.email %></td>
            <td><%= c.phone %></td>
            <td><%= c.registration_date.toISOString().slice(0,10) %></td>
            <td>
              <form method="POST" action="/manage/customers/<%= c.customer_id %>?_method=PATCH" class="inline-form stack-small">
                <input name="first_name" value="<%= c.first_name %>" required />
                <input name="last_name" value="<%= c.last_name %>" required />
                <input type="email" name="email" value="<%= c.email %>" required />
                <input name="phone" value="<%= c.phone %>" required />
                <input name="address_line" value="<%= c.address_line %>" required />
                <input type="date" name="registration_date" value="<%= c.registration_date.toISOString().slice(0,10) %>" required />
                <button type="submit">Save</button>
              </form>
            </td>
            <td>
              <form method="POST" action="/manage/customers/<%= c.customer_id %>?_method=DELETE">
                <button type="submit" class="danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/footer') %>
