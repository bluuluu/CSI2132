<%- include('../partials/header', { title: 'Manage Staff Accounts', message }) %>
<% const showAdminPasswords = auth.role === 'admin'; %>
<% const staffColumnCount = showAdminPasswords ? 12 : 11; %>

<section class="page-intro">
  <h2>Staff Accounts</h2>
  <% if (canManageManagers) { %>
    <p>Create and maintain employee and manager accounts. You can disable or fully delete staff records.</p>
  <% } else { %>
    <p>Create and maintain employee accounts for your hotel. You can disable or fully delete employee records.</p>
  <% } %>
</section>

<section class="card">
  <h2>Create Staff Member</h2>
  <form method="POST" action="/manage/employees" class="grid form-grid">
    <label>SIN
      <input
        name="legal_id"
        type="tel"
        inputmode="numeric"
        pattern="\d{9}"
        minlength="9"
        maxlength="9"
        placeholder="111111111"
        title="SIN must contain exactly 9 digits."
        required
      />
    </label>
    <label>ID Type
      <input value="SIN" readonly />
      <input type="hidden" name="id_type" value="SIN" />
    </label>
    <label>First Name <input name="first_name" maxlength="80" required /></label>
    <label>Last Name <input name="last_name" maxlength="80" required /></label>
    <label>Email <input type="email" name="email" maxlength="120" required /></label>
    <label>Phone
      <input
        name="phone"
        type="tel"
        inputmode="numeric"
        pattern="\d{10}"
        minlength="10"
        maxlength="10"
        title="Phone must contain exactly 10 digits."
        required
      />
    </label>
    <label>Address <input name="address_line" maxlength="255" required /></label>
    <label>Hotel
      <select name="hotel_id" required>
        <% hotels.forEach(h => { %>
          <option value="<%= h.hotel_id %>">#<%= h.hotel_id %> <%= h.hotel_name %></option>
        <% }) %>
      </select>
    </label>
    <label>Role Title <input name="role_title" maxlength="80" required /></label>
    <label>Hired On <input type="date" name="hired_on" required /></label>
    <% if (canManageManagers) { %>
      <label>Account Role
        <select name="account_role" required>
          <option value="employee">Employee</option>
          <option value="manager">Manager</option>
        </select>
      </label>
    <% } else { %>
      <input type="hidden" name="account_role" value="employee" />
    <% } %>
    <label>Username <input name="username" maxlength="60" pattern="[a-z0-9._-]{3,60}" required /></label>
    <label>Password <input type="password" name="password" minlength="6" maxlength="120" required /></label>
    <div class="actions"><button type="submit">Create</button></div>
  </form>
</section>

<section class="card">
  <h2>Existing Staff</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>SIN (Primary ID)</th>
          <th>Employee ID</th>
          <th>Name</th>
          <th>Hotel</th>
          <th>Role Title</th>
          <th>Account Role</th>
          <th>Username</th>
          <% if (showAdminPasswords) { %><th>Password</th><% } %>
          <th>Status</th>
          <th>Update</th>
          <th>Enable/Disable</th>
          <th>Delete</th>
        </tr>
      </thead>
      <tbody>
        <% if (employees.length === 0) { %>
          <tr><td colspan="<%= staffColumnCount %>" class="data-empty">No staff records found.</td></tr>
        <% } %>
        <% employees.forEach(e => { %>
          <tr>
            <td><%= e.legal_id %></td>
            <td><%= e.employee_id %></td>
            <td><%= e.first_name %> <%= e.last_name %></td>
            <td><%= e.hotel_name %></td>
            <td><%= e.role_title %></td>
            <td><%= e.account_role %></td>
            <td><%= e.username %></td>
            <% if (showAdminPasswords) { %><td><%= e.password_plain %></td><% } %>
            <td>
              <span class="status-badge <%= e.is_active ? 'status-active' : 'status-cancelled' %>">
                <%= e.is_active ? 'active' : 'inactive' %>
              </span>
            </td>
            <td>
              <form method="POST" action="/manage/employees/<%= e.employee_id %>?_method=PATCH" class="inline-form stack-small">
                <input name="first_name" value="<%= e.first_name %>" maxlength="80" required />
                <input name="last_name" value="<%= e.last_name %>" maxlength="80" required />
                <input type="email" name="email" value="<%= e.email %>" maxlength="120" required />
                <input
                  name="phone"
                  value="<%= String(e.phone || '').replace(/\D/g, '').slice(0, 10) %>"
                  type="tel"
                  inputmode="numeric"
                  pattern="\d{10}"
                  minlength="10"
                  maxlength="10"
                  title="Phone must contain exactly 10 digits."
                  required
                />
                <input name="address_line" value="<%= e.address_line %>" maxlength="255" required />
                <select name="hotel_id" required>
                  <% hotels.forEach(h => { %>
                    <option value="<%= h.hotel_id %>" <%= h.hotel_id === e.hotel_id ? 'selected' : '' %>>#<%= h.hotel_id %> <%= h.hotel_name %></option>
                  <% }) %>
                </select>
                <input name="role_title" value="<%= e.role_title %>" maxlength="80" required />
                <input type="date" name="hired_on" value="<%= e.hired_on.toISOString().slice(0,10) %>" required />
                <% if (canManageManagers) { %>
                  <select name="account_role" required>
                    <option value="employee" <%= e.account_role === 'employee' ? 'selected' : '' %>>Employee</option>
                    <option value="manager" <%= e.account_role === 'manager' ? 'selected' : '' %>>Manager</option>
                  </select>
                <% } else { %>
                  <input type="hidden" name="account_role" value="employee" />
                <% } %>
                <input name="username" value="<%= e.username %>" maxlength="60" pattern="[a-z0-9._-]{3,60}" required />
                <input type="password" name="password" minlength="6" maxlength="120" placeholder="Leave blank to keep password" />
                <button type="submit">Save</button>
              </form>
            </td>
            <td>
              <form method="POST" action="/manage/employees/<%= e.employee_id %>/account-status?_method=PATCH">
                <input type="hidden" name="is_active" value="<%= e.is_active ? 'false' : 'true' %>" />
                <button type="submit" class="<%= e.is_active ? 'danger' : '' %>">
                  <%= e.is_active ? 'Disable' : 'Enable' %>
                </button>
              </form>
            </td>
            <td>
              <% const canDeleteRow = auth.role === 'admin' || (auth.role === 'manager' && e.account_role === 'employee'); %>
              <% if (canDeleteRow) { %>
                <form method="POST" action="/manage/employees/<%= e.employee_id %>?_method=DELETE">
                  <button type="submit" class="danger">Delete</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/footer') %>
