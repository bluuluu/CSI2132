<%- include('../partials/header', { title: 'Manage Rooms', message }) %>

<section class="page-intro">
  <h2>Room Inventory</h2>
  <p>Control room availability details, pricing, and maintenance statuses.</p>
</section>

<section class="card">
  <h2>Create Room</h2>
  <form method="POST" action="/manage/rooms" class="grid form-grid">
    <label>Hotel
      <select name="hotel_id" required>
        <% hotels.forEach(h => { %><option value="<%= h.hotel_id %>">#<%= h.hotel_id %> <%= h.hotel_name %> (<%= h.city %>)</option><% }) %>
      </select>
    </label>
    <label>Room Number <input name="room_number" maxlength="10" required /></label>
    <label>Capacity
      <select name="capacity" required>
        <% ['single','double','suite','family'].forEach(c => { %><option value="<%= c %>"><%= c %></option><% }) %>
      </select>
    </label>
    <label>Price <input type="number" min="0.01" step="0.01" name="base_price" required /></label>
    <label>Amenities <input name="amenities" maxlength="4000" required /></label>
    <label>Issues <input name="issues" maxlength="4000" /></label>
    <label>Status
      <select name="current_status" required>
        <% ['available','booked','rented','maintenance'].forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
      </select>
    </label>
    <label class="checkline"><input type="checkbox" name="has_sea_view" /> Sea View</label>
    <label class="checkline"><input type="checkbox" name="has_mountain_view" /> Mountain View</label>
    <label class="checkline"><input type="checkbox" name="is_extendable" /> Extendable</label>
    <div class="actions"><button type="submit">Create</button></div>
  </form>
</section>

<section class="card">
  <h2>Rooms</h2>
  <div class="table-wrap">
    <table>
      <thead><tr><th>ID</th><th>Hotel</th><th>#</th><th>Capacity</th><th>Price</th><th>Status</th><th>Update</th><th>Delete</th></tr></thead>
      <tbody>
      <% if (rooms.length === 0) { %>
        <tr><td colspan="8" class="data-empty">No room records found.</td></tr>
      <% } %>
      <% rooms.forEach(r => { %>
        <tr>
          <td><%= r.room_id %></td>
          <td><%= r.hotel_id %></td>
          <td><%= r.room_number %></td>
          <td><%= r.capacity %></td>
          <td>$<%= r.base_price %></td>
          <td><span class="status-badge status-<%= (r.current_status || '').replace(/[^a-z_]/g, '_') %>"><%= r.current_status %></span></td>
          <td>
            <form method="POST" action="/manage/rooms/<%= r.room_id %>?_method=PATCH" class="inline-form stack-small">
              <select name="hotel_id" required>
                <% hotels.forEach(h => { %>
                  <option value="<%= h.hotel_id %>" <%= h.hotel_id === r.hotel_id ? 'selected' : '' %>>#<%= h.hotel_id %> <%= h.hotel_name %></option>
                <% }) %>
              </select>
              <input name="room_number" value="<%= r.room_number %>" maxlength="10" required />
              <select name="capacity" required>
                <% ['single','double','suite','family'].forEach(c => { %>
                  <option value="<%= c %>" <%= c === r.capacity ? 'selected' : '' %>><%= c %></option>
                <% }) %>
              </select>
              <input type="number" min="0.01" step="0.01" name="base_price" value="<%= r.base_price %>" required />
              <input name="amenities" value="<%= r.amenities %>" maxlength="4000" required />
              <input name="issues" value="<%= r.issues || '' %>" maxlength="4000" />
              <select name="current_status" required>
                <% ['available','booked','rented','maintenance'].forEach(s => { %>
                  <option value="<%= s %>" <%= s === r.current_status ? 'selected' : '' %>><%= s %></option>
                <% }) %>
              </select>
              <label class="checkline"><input type="checkbox" name="has_sea_view" <%= r.has_sea_view ? 'checked' : '' %> />Sea</label>
              <label class="checkline"><input type="checkbox" name="has_mountain_view" <%= r.has_mountain_view ? 'checked' : '' %> />Mountain</label>
              <label class="checkline"><input type="checkbox" name="is_extendable" <%= r.is_extendable ? 'checked' : '' %> />Extend</label>
              <button type="submit">Save</button>
            </form>
          </td>
          <td>
            <form method="POST" action="/manage/rooms/<%= r.room_id %>?_method=DELETE">
              <button type="submit" class="danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/footer') %>
