<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <% const isAuthenticated = auth && auth.isAuthenticated; %>
      <% const role = isAuthenticated ? auth.role : null; %>
      <div class="header-shell">
        <a href="/" class="brand-link" aria-label="eHotels Home">
          <span class="brand-mark">E</span>
          <span class="brand-name">eHotels</span>
        </a>

        <nav class="main-nav">
          <% if (isAuthenticated) { %>
            <a href="/" data-nav>Home</a>
            <a href="/search" data-nav>Browse Rooms</a>
            <% if (['employee', 'manager', 'admin'].includes(role)) { %>
              <a href="/employee" data-nav>Employee Panel</a>
              <a href="/manage/customers" data-nav>Customers</a>
            <% } %>
            <% if (['manager', 'admin'].includes(role)) { %>
              <a href="/manage/employees" data-nav>Staff Accounts</a>
            <% } %>
            <% if (role === 'admin') { %>
              <a href="/views" data-nav>SQL Views</a>
              <a href="/manage/hotels" data-nav>Hotels CRUD</a>
              <a href="/manage/rooms" data-nav>Rooms CRUD</a>
            <% } %>
          <% } else { %>
            <a href="/login" data-nav>Login</a>
          <% } %>
        </nav>

        <% if (isAuthenticated) { %>
          <div class="header-actions">
            <div class="session-badges">
              <span class="badge-pill role-pill"><%= role.toUpperCase() %></span>
              <span class="badge-pill"><%= auth.displayName %></span>
            </div>
            <form method="POST" action="/logout" class="logout-form">
              <button type="submit" class="btn-secondary header-logout">Log Out</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  </header>
  <main class="container">
    <% if (message) { %>
      <div class="alert <%= message.type %>"><%= message.text %></div>
    <% } %>
