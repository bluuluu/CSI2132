<%- include('partials/header', { title: 'Customer Search', message }) %>

<section class="card">
  <h2>Search Available Rooms</h2>
  <form method="GET" action="/search" class="grid form-grid" id="searchForm">
    <label>Start Date <input type="date" name="start_date" value="<%= filters.start_date || '' %>" /></label>
    <label>End Date <input type="date" name="end_date" value="<%= filters.end_date || '' %>" /></label>
    <label>Capacity
      <select name="capacity">
        <option value="">Any</option>
        <% ['single','double','suite','family'].forEach(c => { %>
          <option value="<%= c %>" <%= filters.capacity === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
    </label>
    <label>Area (City)
      <select name="city">
        <option value="">Any</option>
        <% cities.forEach(row => { %>
          <option value="<%= row.city %>" <%= filters.city === row.city ? 'selected' : '' %>><%= row.city %></option>
        <% }) %>
      </select>
    </label>
    <label>Hotel Chain
      <select name="chain_id">
        <option value="">Any</option>
        <% chains.forEach(c => { %>
          <option value="<%= c.chain_id %>" <%= String(filters.chain_id || '') === String(c.chain_id) ? 'selected' : '' %>><%= c.chain_name %></option>
        <% }) %>
      </select>
    </label>
    <label>Hotel Category
      <select name="category">
        <option value="">Any</option>
        <% [1,2,3,4,5].forEach(cat => { %>
          <option value="<%= cat %>" <%= String(filters.category || '') === String(cat) ? 'selected' : '' %>><%= cat %> star</option>
        <% }) %>
      </select>
    </label>
    <label>Min Hotel Rooms <input type="number" min="1" name="total_rooms_min" value="<%= filters.total_rooms_min || '' %>" /></label>
    <label>Max Room Price <input type="number" min="1" step="0.01" name="max_price" value="<%= filters.max_price || '' %>" /></label>
    <div class="actions">
      <button type="submit">Search</button>
      <a href="/search" class="btn-secondary">Reset</a>
    </div>
  </form>
  <p class="muted">Tip: changing any criteria updates the available room list after pressing Search.</p>
</section>

<section class="card">
  <h2>Available Rooms (<%= rooms.length %>)</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Room ID</th><th>Room #</th><th>Hotel</th><th>Chain</th><th>City</th><th>Category</th>
          <th>Capacity</th><th>Price</th><th>Amenities</th><th>Book</th>
        </tr>
      </thead>
      <tbody>
        <% rooms.forEach(room => { %>
          <tr>
            <td><%= room.room_id %></td>
            <td><%= room.room_number %></td>
            <td><%= room.hotel_name %></td>
            <td><%= room.chain_name %></td>
            <td><%= room.city %></td>
            <td><%= room.category %> star</td>
            <td><%= room.capacity %></td>
            <td>$<%= room.base_price %></td>
            <td><%= room.amenities %></td>
            <td>
              <form method="POST" action="/bookings" class="inline-form">
                <input type="hidden" name="room_id" value="<%= room.room_id %>" />
                <select name="customer_id" required>
                  <option value="">Customer</option>
                  <% customers.forEach(c => { %>
                    <option value="<%= c.customer_id %>">#<%= c.customer_id %> <%= c.first_name %> <%= c.last_name %></option>
                  <% }) %>
                </select>
                <input type="number" name="employee_id" placeholder="Emp ID (opt)" min="1" />
                <input type="date" name="start_date" value="<%= filters.start_date || '' %>" required />
                <input type="date" name="end_date" value="<%= filters.end_date || '' %>" required />
                <button type="submit">Book</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<script>
  document.querySelectorAll('#searchForm select').forEach((el) => {
    el.addEventListener('change', () => document.getElementById('searchForm').submit());
  });
</script>

<%- include('partials/footer') %>
