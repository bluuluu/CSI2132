<%- include('partials/header', { title: 'Choose Login Role', message }) %>

<section class="page-intro">
  <h2>Select Your Portal</h2>
  <p>Use separate login pages for each role. Permissions are enforced server-side.</p>
</section>

<section class="grid role-grid">
  <article class="card role-card">
    <h3>Customer Portal</h3>
    <p>Book rooms with filter-based availability and customer-safe access controls.</p>
    <a href="/login/customer" class="btn-secondary block-btn">Go to Customer Login</a>
    <a href="/signup/customer" class="btn-secondary block-btn">Create Customer Account</a>
  </article>

  <article class="card role-card">
    <h3>Staff Portal</h3>
    <p>Single login for employees and managers, with permissions applied after sign-in.</p>
    <a href="/login/employee" class="btn-secondary block-btn">Go to Employee Login</a>
  </article>

  <article class="card role-card">
    <h3>Admin Portal</h3>
    <p>Full access to all workflows, including hotel, room, employee, and customer CRUD.</p>
    <a href="/login/admin" class="btn-secondary block-btn">Go to Admin Login</a>
  </article>
</section>

<%- include('partials/footer') %>
